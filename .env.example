# ====================================
# 暖暖记忆助手 — 环境变量配置模板
# ====================================
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env

# [必填] 智谱 AI API Key
# 获取地址：https://open.bigmodel.cn/
# 注册后在 API Keys 页面获取
ZHIPU_API_KEY=your-zhipu-api-key-here

# [选填] 对话模型（默认 glm-4-flash-250414，免费）
LOCAL_AGENT_MODEL=glm-4-flash-250414

# [选填] 图片理解模型（默认 glm-4v-flash，免费）
LOCAL_AGENT_VISION_MODEL=glm-4v-flash

# [选填] 百度语音（语音功能需要，不填则语音功能不可用）
# 获取地址：https://ai.baidu.com/ — 创建应用后获取
BAIDU_APP_ID=your-baidu-app-id
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# [选填] 管理员密码（管理后台需要）
ADMIN_KEY=your-admin-password

# [选填] 服务器地址（默认 http://127.0.0.1:5000，一般无需修改）
# SERVER_URL=http://127.0.0.1:5000

# [选填] 服务端口（默认 5000）
# PORT=5000

# [选填] 数据目录（默认 ./data）
# DATA_DIR=./data
